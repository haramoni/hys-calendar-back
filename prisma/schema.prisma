generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model people {
  id         String     @id @default(uuid()) @db.Char(36)
  name       String     @db.VarChar(255)
  created_at DateTime   @default(now()) @db.DateTime(6)
  updated_at DateTime   @updatedAt @db.DateTime(6)
  logbooks   logbooks[]
}

model calendar_months {
  id           String         @id @default(uuid()) @db.Char(36)
  year         Int
  month        Int
  starts_at    DateTime       @db.Date
  ends_at      DateTime       @db.Date
  created_at   DateTime       @default(now()) @db.DateTime(6)
  updated_at   DateTime       @updatedAt @db.DateTime(6)
  stand_events stand_events[]

  @@unique([year, month], map: "unique_calendar_month")
  @@index([year, month], map: "idx_calendar_months_year_month")
}

model stand_event_days {
  id             String       @id @default(uuid()) @db.Char(36)
  date           DateTime     @db.Date
  stage          event_stage
  stand_event_id String       @db.Char(36)
  created_at     DateTime     @default(now()) @db.DateTime(6)
  updated_at     DateTime     @updatedAt @db.DateTime(6)

  stand_events stand_events @relation(
    fields: [stand_event_id],
    references: [id],
    onDelete: Cascade,
    onUpdate: NoAction,
    map: "fk_stand_event_days_stand_event"
  )

  @@index([date], map: "idx_stand_event_days_date")
  @@index([stand_event_id], map: "idx_stand_event_days_stand_event_id")
}

model stand_events {
  id                String             @id @default(uuid()) @db.Char(36)
  stand_name        String             @db.VarChar(255)
  supplier_name     String             @db.VarChar(255)
  location          String             @db.VarChar(255)
  calendar_month_id String             @db.Char(36)
  created_at        DateTime           @default(now()) @db.DateTime(6)
  updated_at        DateTime           @updatedAt @db.DateTime(6)

  stand_event_days stand_event_days[]
  calendar_months  calendar_months @relation(
    fields: [calendar_month_id],
    references: [id],
    onDelete: Cascade,
    onUpdate: NoAction,
    map: "fk_stand_events_calendar_month"
  )

  @@index([calendar_month_id], map: "idx_stand_events_calendar_month_id")
}

model logbooks {
  id         String   @id @default(uuid()) @db.Char(36)
  value      Decimal  @db.Decimal(10, 2)
  date       DateTime @db.Date
  reason     String   @db.VarChar(255)
  person_id  String   @db.Char(36)
  created_at DateTime @default(now()) @db.DateTime(6)
  updated_at DateTime @updatedAt @db.DateTime(6)

  people people @relation(
    fields: [person_id],
    references: [id],
    onUpdate: NoAction,
    map: "fk_logbooks_person"
  )

  @@index([date], map: "idx_logbooks_date")
  @@index([person_id], map: "idx_logbooks_person_id")
}

enum event_stage {
  MONTAGEM
  EVENTO
  DESMONTAGEM
  EVENTO_COMPLETO
}

enum logbook_type {
  ENTRADA
  SAIDA
}