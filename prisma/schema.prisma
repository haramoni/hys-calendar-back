generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model calendar_months {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year         Int
  month        Int
  starts_at    DateTime       @db.Date
  ends_at      DateTime       @db.Date
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime       @default(now()) @db.Timestamp(6)
  stand_events stand_events[]

  @@unique([year, month], map: "unique_calendar_month")
  @@index([year, month], map: "idx_calendar_months_year_month")
}

model stand_event_days {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date           DateTime     @db.Date
  stage          event_stage
  stand_event_id String       @db.Uuid
  created_at     DateTime     @default(now()) @db.Timestamp(6)
  updated_at     DateTime     @default(now()) @db.Timestamp(6)
  stand_events   stand_events @relation(fields: [stand_event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stand_event_days_stand_event")

  @@index([date], map: "idx_stand_event_days_date")
  @@index([stand_event_id], map: "idx_stand_event_days_stand_event_id")
}

model stand_events {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stand_name        String             @db.VarChar(255)
  supplier_name     String             @db.VarChar(255)
  location          String             @db.VarChar(255)
  calendar_month_id String             @db.Uuid
  created_at        DateTime           @default(now()) @db.Timestamp(6)
  updated_at        DateTime           @default(now()) @db.Timestamp(6)
  stand_event_days  stand_event_days[]
  calendar_months   calendar_months    @relation(fields: [calendar_month_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_stand_events_calendar_month")

  @@index([calendar_month_id], map: "idx_stand_events_calendar_month_id")
}

enum event_stage {
  MONTAGEM
  EVENTO
  DESMONTAGEM
  EVENTO_COMPLETO
}
